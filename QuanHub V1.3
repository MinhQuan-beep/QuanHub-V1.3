ServerTab:CreateSection("Hệ Thống Kết Nối Server")

ServerTab:CreateButton({
    Name = "Vào Lại Server",
    Callback = function()
        local currentPlaceId = game.PlaceId
        local currentPlayer = player
        TeleportService:Teleport(currentPlaceId, currentPlayer)
    end
})

ServerTab:CreateButton({
    Name = "Đổi Server",
    Callback = function()
        local success, servers = pcall(function()
            return HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"))
        end)
        
        if success then
            for _, server in pairs(servers.data) do
                if server.playing < server.maxPlayers and server.playing >= 1 then
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, player)
                    break
                end
            end
        end
    end
})

ServerTab:CreateSection("Tối Ưu Hiệu Năng")

ServerTab:CreateButton({
    Name = "Mở Khóa FPS",
    Callback = function()
        if setfpscap then
            setfpscap(999)
            Rayfield:Notify({Title = "Máy Chủ", Content = "Đã mở giới hạn lên 999 FPS", Duration = 3})
        else
            Rayfield:Notify({Title = "Lỗi", Content = "Executor không hỗ trợ mở FPS", Duration = 3})
        end
    end
})

