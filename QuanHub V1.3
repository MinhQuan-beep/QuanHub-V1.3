local function LifeWatcher()
    LocalPlayer.CharacterAdded:Connect(function(char)
        local hum = char:WaitForChild("Humanoid")
        hum.Died:Connect(function()
            GlobalNotify("Cảnh báo", "Bạn đã tử vong. Hệ thống đang chờ...")
        end)
        task.wait(1.5)
        GlobalNotify("Quân Hub", "Dữ liệu người chơi đã làm mới.")
    end)
end
spawn(LifeWatcher)

