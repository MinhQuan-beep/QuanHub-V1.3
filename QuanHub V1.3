-- 13. Aura Slap (Tính năng mới 1)
MainTab:CreateToggle({
    Name = "13. Aura Slap (Tầm Đánh)",
    CurrentValue = false,
    Callback = function(Value)
        _G.AuraSlapEnabled = Value
        spawn(function()
            while _G.AuraSlapEnabled do
                pcall(function()
                    for _, target in pairs(Players:GetPlayers()) do
                        if target ~= player and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                            local distance = (player.Character.HumanoidRootPart.Position - target.Character.HumanoidRootPart.Position).Magnitude
                            if distance < 18 then
                                local tool = player.Character:FindFirstChildOfClass("Tool")
                                if tool then tool:Activate() end
                            end
                        end
                    end
                end)
                task.wait(0.1)
            end
        end)
    end,
})

-- 14. Anti Void (Tính năng mới 2)
MainTab:CreateToggle({
    Name = "14. Anti Void (Chống Rơi Map)",
    CurrentValue = false,
    Callback = function(Value)
        _G.AntiVoidEnabled = Value
        spawn(function()
            while _G.AntiVoidEnabled do
                if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    if player.Character.HumanoidRootPart.Position.Y < -40 then
                        player.Character.HumanoidRootPart.Velocity = Vector3.new(0, 60, 0)
                    end
                end
                task.wait(0.3)
            end
        end)
    end,
})

-- 15. Anti Ban (Tính năng mới 3)
MainTab:CreateToggle({
    Name = "15. Anti Ban (Bảo Vệ)",
    CurrentValue = false,
    Callback = function(Value)
        _G.AntiBanProtector = Value
        if Value then
            local mt = getrawmetatable(game)
            setreadonly(mt, false)
            local old = mt.__namecall
            mt.__namecall = newcclosure(function(self, ...)
                local method = getnamecallmethod()
                if method == "Kick" or method == "ReportAbuse" then return nil end
                return old(self, ...)
            end)
            Rayfield:Notify({Title = "Quân Hub", Content = "Đã kích hoạt bảo mật Anti-Ban!", Duration = 3})
        end
    end,
})

