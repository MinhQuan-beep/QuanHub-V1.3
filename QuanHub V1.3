-- Quản lý nhân vật hồi sinh
local function LifeCycleManager()
    LocalPlayer.CharacterAdded:Connect(function(char)
        local hum = char:WaitForChild("Humanoid")
        hum.Died:Connect(function()
            QuickNotify("Cảnh báo", "Bạn đã tử vong. Hệ thống đang chờ hồi sinh...")
        end)
        task.wait(1.5)
        QuickNotify("Quân Hub", "Dữ liệu nhân vật đã được nạp lại.")
    end)
end
spawn(LifeCycleManager)

