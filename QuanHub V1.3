MainTab:CreateButton({
    Name = "11. Menu Dịch Chuyển (Lưu Vị Trí)", 
    Callback = function()
        local savedPos = nil
        if not player:WaitForChild("PlayerGui"):FindFirstChild("RightMenu") then
            local gui = Instance.new("ScreenGui", player.PlayerGui)
            gui.Name = "RightMenu"
            gui.ResetOnSpawn = false
            local frame = Instance.new("Frame", gui)
            frame.Size = UDim2.new(0,180,0,180)
            frame.Position = UDim2.new(1,-190,0.35,0)
            frame.BackgroundColor3 = Color3.fromRGB(45,45,45)
            frame.Active = true frame.Draggable = true
            local title = Instance.new("TextLabel", frame)
            title.Size = UDim2.new(1,0,0,35)
            title.BackgroundColor3 = Color3.fromRGB(30,30,30)
            title.Text = "MENU TP" title.TextColor3 = Color3.new(1,1,1)
            title.Font = Enum.Font.GothamBold title.TextSize = 20
            local saveBtn = Instance.new("TextButton", frame)
            saveBtn.Size = UDim2.new(1,-20,0,40)
            saveBtn.Position = UDim2.new(0,10,0,45)
            saveBtn.Text = "Lưu vị trí"
            local tpBtn = Instance.new("TextButton", frame)
            tpBtn.Size = UDim2.new(1,-20,0,40)
            tpBtn.Position = UDim2.new(0,10,0,95)
            tpBtn.Text = "Dịch chuyển"
            saveBtn.MouseButton1Click:Connect(function()
                if player.Character then
                    savedPos = player.Character:WaitForChild("HumanoidRootPart").CFrame
                    Rayfield:Notify({Title = "Thành công", Content = "Đã lưu tọa độ!", Duration = 2})
                end
            end)
            tpBtn.MouseButton1Click:Connect(function()
                if player.Character and savedPos then
                    player.Character:WaitForChild("HumanoidRootPart").CFrame = savedPos
                end
            end)
        end
    end
})

