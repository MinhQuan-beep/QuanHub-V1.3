---------------------------------------------------------------------------
local CoreServices = setmetatable({}, {
    __index = function(self, serviceName)
        local success, service = pcall(game.GetService, game, serviceName)
        if success and service then
            self[serviceName] = service
            return service
        end
        return nil
    end
})

local Players = CoreServices.Players
local RunService = CoreServices.RunService
local UIS = CoreServices.UserInputService
local TeleportService = CoreServices.TeleportService
local HttpService = CoreServices.HttpService
