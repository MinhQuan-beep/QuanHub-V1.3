-- [ PHẦN 4: MODULE WASD MOBILE CHUYÊN SÂU - BY IRO ]
---------------------------------------------------------------------------
local function InitializeWASDMobile()
    -- Xử lý ẩn các thành phần di chuyển mặc định của Roblox
    local function hideDefaultControls()
        local touchGui = PlayerGui:FindFirstChild("TouchGui")
        if touchGui then
            local controlFrame = touchGui:FindFirstChild("TouchControlFrame")
            if controlFrame then
                local dynamicStick = controlFrame:FindFirstChild("DynamicThumbstickFrame")
                local normalStick = controlFrame:FindFirstChild("JoystickFrame")
                
                if dynamicStick then 
                    dynamicStick.Visible = false 
                end
                if normalStick then 
                    normalStick.Visible = false 
                end
                
                local jumpBtn = controlFrame:FindFirstChild("JumpButton")
                if jumpBtn then 
                    jumpBtn.Visible = true 
                end
            end
        end
    end
    
    hideDefaultControls()
    PlayerGui.ChildAdded:Connect(hideDefaultControls)

    -- Kiểm tra và dọn dẹp phiên bản cũ để tránh rác bộ nhớ
    if PlayerGui:FindFirstChild("Iro_WASD_Controller") then 
        PlayerGui.Iro_WASD_Controller:Destroy() 
    end

    -- Khởi tạo Giao diện Phím WASD
    local wasdScreen = Instance.new("ScreenGui")
    wasdScreen.Name = "Iro_WASD_Controller"
    wasdScreen.ResetOnSpawn = false
    wasdScreen.Parent = PlayerGui

    -- Hàm tạo nút bấm tùy chỉnh với hiệu ứng Tween
    local function createDpadButton(name, label, position)
        local btn = Instance.new("TextButton")
        btn.Name = name
        btn.Text = label
        btn.Position = position
        btn.Size = UDim2.new(0, 55, 0, 55)
        btn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        btn.BackgroundTransparency = 0.4
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.Font = Enum.Font.SourceSansBold
        btn.TextSize = 22
        btn.Parent = wasdScreen
        
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(1, 0)
        corner.Parent = btn
        
        local stroke = Instance.new("UIStroke")
        stroke.Thickness = 2
        stroke.Color = Color3.fromRGB(255, 255, 255)
        stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        stroke.Parent = btn
        
        return btn
    end

    -- Sắp xếp vị trí các nút theo chuẩn D-Pad
    local basePos = UDim2.new(0, 130, 0.6, 0)
    local W = createDpadButton("ButtonW", "W", basePos + UDim2.new(0, -27, 0, -65))
    local S = createDpadButton("ButtonS", "S", basePos + UDim2.new(0, -27, 0, 35))
    local A = createDpadButton("ButtonA", "A", basePos + UDim2.new(0, -85, 0, -15))
    local D = createDpadButton("ButtonD", "D", basePos + UDim2.new(0, 30, 0, -15))

    -- Trạng thái điều hướng (Movement States)
    local moveDir = {
        Forward = 0,
        Backward = 0,
        Left = 0,
        Right = 0
    }

    -- Kết nối sự kiện tương tác chạm (Touch Events)
    local function bindControl(button, key, value)
        button.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                moveDir[key] = value
                TweenService:Create(button, TweenInfo.new(0.1), {BackgroundTransparency = 0.1, BackgroundColor3 = Color3.fromRGB(100, 100, 100)}):Play()
            end
        end)
        
        button.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                moveDir[key] = 0
                TweenService:Create(button, TweenInfo.new(0.1), {BackgroundTransparency = 0.4, BackgroundColor3 = Color3.fromRGB(20, 20, 20)}):Play()
            end
        end)
    end

    bindControl(W, "Forward", 1)
    bindControl(S, "Backward", 1)
    bindControl(A, "Left", 1)
    bindControl(D, "Right", 1)

    -- Vòng lặp RenderStepped để áp dụng lực di chuyển liên tục
    RunService.RenderStepped:Connect(function()
        local humanoid = GetHumanoid()
        if humanoid then
            local moveVector = Vector3.new(moveDir.Right - moveDir.Left, 0, moveDir.Backward - moveDir.Forward)
            humanoid:Move(moveVector, true)
        end
    end)
    
    SendNotification("Hệ Thống", "Đã kích hoạt phím di chuyển WASD Mobile!")
end

