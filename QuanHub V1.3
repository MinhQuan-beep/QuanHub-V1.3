ServerTab:CreateSection("Hệ Thống Server")

ServerTab:CreateButton({
    Name = "Vào Lại Server (Rejoin)",
    Callback = function()
        TeleportService:Teleport(game.PlaceId, player)
    end
})

ServerTab:CreateButton({
    Name = "Tìm Server Ít Người (Server Hop)",
    Callback = function()
        local list = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"))
        for _, v in pairs(list.data) do
            if v.playing < v.maxPlayers and v.playing >= 1 then
                TeleportService:TeleportToPlaceInstance(game.PlaceId, v.id, player)
                break
            end
        end
    end
})

