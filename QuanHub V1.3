local function SavePremiumStatus()
    if writefile then
        writefile("QuanHub_Premium_V12.txt", "Unlocked")
    end
end

local function IsPremiumUnlocked()
    if isfile and isfile("QuanHub_Premium_V13.txt") then
        return readfile("QuanHub_Premium_V13.txt") == "Unlocked"
    end
    return false
end

