            Rayfield:Notify({Title = "Quân Hub", Content = "Đã mở khóa giới hạn FPS lên 999!", Duration = 3})
        else
            Rayfield:Notify({Title = "Lỗi", Content = "Executor của bạn không hỗ trợ tính năng này!", Duration = 3})
