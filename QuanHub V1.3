-- // TÍNH NĂNG THỨ 11: MENU DỊCH CHUYỂN
MainTab:CreateButton({
    Name = "11. Menu Dịch Chuyển (Lưu Vị Trí)", 
    Callback = function()
        local plr = Players.LocalPlayer
        local savedPos = nil
        
        if not plr:WaitForChild("PlayerGui"):FindFirstChild("RightMenu") then
            local gui = Instance.new("ScreenGui")
            gui.Name = "RightMenu"
            gui.ResetOnSpawn = false
            gui.Parent = plr.PlayerGui
            
            local frame = Instance.new("Frame", gui)
            frame.Size = UDim2.new(0,180,0,180)
            frame.Position = UDim2.new(1,-190,0.35,0)
            frame.BackgroundColor3 = Color3.fromRGB(45,45,45)
            frame.BorderSizePixel = 0
            frame.Active = true
            frame.Draggable = true
            
            local title = Instance.new("TextLabel", frame)
            title.Size = UDim2.new(1,0,0,35)
            title.BackgroundColor3 = Color3.fromRGB(30,30,30)
            title.Text = "MENU TP"
            title.Font = Enum.Font.GothamBold
            title.TextSize = 20
            title.TextColor3 = Color3.new(1,1,1)
            
            local saveBtn = Instance.new("TextButton", frame)
            saveBtn.Size = UDim2.new(1,-20,0,40)
            saveBtn.Position = UDim2.new(0,10,0,45)
            saveBtn.Text = "Lưu vị trí"
            
            local tpBtn = Instance.new("TextButton", frame)
            tpBtn.Size = UDim2.new(1,-20,0,40)
            tpBtn.Position = UDim2.new(0,10,0,95)
            tpBtn.Text = "Dịch chuyển"
            
            saveBtn.MouseButton1Click:Connect(function()
                local char = plr.Character
                if char then
                    savedPos = char:WaitForChild("HumanoidRootPart").CFrame
                    Rayfield:Notify({Title = "Thành công", Content = "Đã lưu vị trí!", Duration = 2})
                end
            end)
            
            tpBtn.MouseButton1Click:Connect(function()
                local char = plr.Character
                if char and savedPos then
                    char:WaitForChild("HumanoidRootPart").CFrame = savedPos
                else
                    Rayfield:Notify({Title = "Lỗi", Content = "Chưa lưu vị trí!", Duration = 2})
                end
            end)
        end
    end
})

--- [[ HÀM TẢI TÍNH NĂNG PREMIUM ]] ---
local function LoadPremiumFeatures()
    PremiumTab:CreateSection("🔥 Tuyệt Kỹ VIP")

    PremiumTab:CreateToggle({
        Name = "1. Chế Độ Bán Bất Tử (Semi-God)",
        CurrentValue = false,
        Callback = function(Value)
            _G.SemiGod = Value
            spawn(function()
                while _G.SemiGod do
                    if player.Character and player.Character:FindFirstChild("Humanoid") then
                        if player.Character.Humanoid.Health < 25 then
                            player.Character.Humanoid.Health = 100
                        end
                    end
                    task.wait(0.1)
                end
            end)
        end,
    })

    PremiumTab:CreateButton({
        Name = "2. Tìm Server Ít Người (Vắng)",
        Callback = function()
            local HttpService = game:GetService("HttpService")
            local list = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"))
            for _, v in pairs(list.data) do
                if v.playing < v.maxPlayers and v.playing <= 3 then
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, v.id, player)
                    break
                end
            end
        end,
    })

    PremiumTab:CreateButton({
        Name = "3. Kích Hoạt Shader Menu (Icon)",
        Callback = function()
            local ScreenGui = Instance.new("ScreenGui", game.CoreGui)
            local MainButton = Instance.new("ImageButton", ScreenGui)
            local ShaderFrame = Instance.new("Frame", ScreenGui)
            MainButton.Size = UDim2.new(0, 50, 0, 50)
            MainButton.Position = UDim2.new(0.05, 0, 0.4, 0)
            MainButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            MainButton.Image = "rbxassetid://6031094678"
            MainButton.Draggable = true MainButton.Active = true
            ShaderFrame.Size = UDim2.new(0, 160, 0, 180)
            ShaderFrame.Position = UDim2.new(0.05, 60, 0.4, 0)
            ShaderFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
            ShaderFrame.Visible = false
            local function CreateShaderOpt(name, callback)
                local btn = Instance.new("TextButton", ShaderFrame)
                btn.Size = UDim2.new(1, 0, 0, 45)
                btn.Position = UDim2.new(0, 0, 0, #ShaderFrame:GetChildren()*45 - 45)
                btn.Text = name btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
                btn.TextColor3 = Color3.new(1,1,1) btn.Font = Enum.Font.SourceSansBold
                btn.MouseButton1Click:Connect(callback)
            end
            MainButton.MouseButton1Click:Connect(function() ShaderFrame.Visible = not ShaderFrame.Visible end)
            CreateShaderOpt("HDR Tươi Màu", function() local b = Instance.new("ColorCorrectionEffect", Lighting) b.Contrast = 0.2 b.Saturation = 0.5 end)
            CreateShaderOpt("Hiệu Ứng Bloom", function() Instance.new("BloomEffect", Lighting).Intensity = 1 end)
            CreateShaderOpt("Hiệu Ứng DOF", function() Instance.new("DepthOfFieldEffect", Lighting).FarIntensity = 0.5 end)
            CreateShaderOpt("Xóa Shader", function() for _, v in pairs(Lighting:GetChildren()) do if v:IsA("PostEffect") or v:IsA("ColorCorrectionEffect") then v:Destroy() end end end)
            Rayfield:Notify({Title = "Shader", Content = "Đã hiện Icon Shader!", Duration = 3})
        end,
    })

    PremiumTab:CreateSection("⚡ Chỉ Số VIP")
    PremiumTab:CreateSlider({
        Name = "Tốc Độ Chạy (Speed)",
        Range = {16, 500},
        Increment = 1,
        CurrentValue = 16,
        Callback = function(v) if player.Character then player.Character.Humanoid.WalkSpeed = v end end,
    })
    
    PremiumTab:CreateSlider({
        Name = "Lực Nhảy (Jump Power)",
        Range = {50, 800},
        Increment = 1,
        CurrentValue = 50,
        Callback = function(v) 
            if player.Character then 
                player.Character.Humanoid.JumpPower = v 
                player.Character.Humanoid.UseJumpPower = true 
            end 
        end,
    })
end

