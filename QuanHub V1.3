-- Hàm tự động thông báo khi có lỗi xảy ra (pcall)
local function SafeExecute(name, func)
    local success, err = pcall(func)
    if not success then
        warn("Quân Hub Error ["..name.."]: "..err)
        Rayfield:Notify({Title="Lỗi Hệ Thống", Content="Không thể chạy "..name, Duration=5})
    end
end

