-- [ PHẦN 3: HÀM TIỆN ÍCH NÂNG CAO (UTILITIES) ]
---------------------------------------------------------------------------
local function SendNotification(title, content)
    Rayfield:Notify({
        Title = title,
        Content = content,
        Duration = 4,
        Image = 4483362458,
    })
end

local function ExecuteScript(taskName, func)
    local success, err = pcall(func)
    if not success then
        warn(QuanHub_Config.Metadata.Tag .. " Error: " .. taskName .. " | " .. tostring(err))
    end
end

