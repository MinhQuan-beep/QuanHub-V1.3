-- Hệ thống Server
ExtraTab:CreateButton({
    Name = "Sever hop",
    Callback = function()
        QuickNotify("Hệ Thống", "Đang chuyển máy chủ ngẫu nhiên...")
        local Api = "https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Desc&limit=100"
        local Raw = game:HttpGet(Api)
        local Data = HttpService:JSONDecode(Raw)
        local Target = Data.data[math.random(1, #Data.data)]
        if Target then TeleportService:TeleportToPlaceInstance(game.PlaceId, Target.id, LocalPlayer) end
    end
})

ExtraTab:CreateButton({
    Name = "Sever hop (vắng)",
    Callback = function()
        QuickNotify("Hệ Thống", "Đang tìm máy chủ ít người chơi nhất...")
        local function GetSmall()
            local Api = "https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100"
            local Raw = game:HttpGet(Api)
            local Data = HttpService:JSONDecode(Raw)
            for _, s in pairs(Data.data) do
                if s.playing < s.maxPlayers and s.playing > 0 then return s.id end
            end
        end
        local sid = GetSmall()
        if sid then TeleportService:TeleportToPlaceInstance(game.PlaceId, sid, LocalPlayer) end
    end
})

