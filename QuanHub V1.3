local function GlobalNotify(title, content)
    Rayfield:Notify({
        Title = title,
        Content = content,
        Duration = 5,
        Image = 4483362458,
    })
end

local function SafeExecute(name, func)
    local s, e = pcall(func)
    if not s then
        warn(QuanHub_Registry.Meta.Tag .. " Lỗi hệ thống tại: " .. name .. " | " .. tostring(e))
    end
end

