local function SendNotification(title, content, duration)
    Rayfield:Notify({
        Title = title,
        Content = content,
        Duration = duration or 5,
        Image = 4483362458,
    })
end

local function SafeLoad(name, url)
    local success, err = pcall(function()
        loadstring(game:HttpGet(url))()
    end)
    if not success then
        warn("Quân Hub | Lỗi khi tải " .. name .. ": " .. tostring(err))
    end
end

