-- [ PHẦN 4: HÀM HỖ TRỢ CHI TIẾT (HELPER FUNCTIONS) ]
---------------------------------------------------------------------------
local function GetCharacter()
    local Char = LocalPlayer.Character
    if Char then
        return Char
    end
    return nil
end

local function GetHumanoid()
    local Char = GetCharacter()
    if Char then
        local Hum = Char:FindFirstChildOfClass("Humanoid")
        if Hum then
            return Hum
        end
    end
    return nil
end

local function GetRootPart()
    local Char = GetCharacter()
    if Char then
        local Root = Char:FindFirstChild("HumanoidRootPart")
        if Root then
            return Root
        end
    end
    return nil
end

local function CreateNotification(title, msg, time)
    Rayfield:Notify({
        Title = title,
        Content = msg,
        Duration = time or 5,
        Image = 4483345998,
    })
end

