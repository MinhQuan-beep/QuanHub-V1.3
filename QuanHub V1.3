-- [ PHẦN 5: MODULE WASD MOBILE - BY IRO (VIẾT CHI TIẾT 180 DÒNG) ]
---------------------------------------------------------------------------
local function Initialize_WASD_Iro()
    -- Kiểm tra nếu GUI đã tồn tại thì xóa đi để tránh lỗi
    if LocalPlayer.PlayerGui:FindFirstChild("Iro_WASD_V13") then
        LocalPlayer.PlayerGui.Iro_WASD_V13:Destroy()
    end

    -- Tạo ScreenGui mới
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "Iro_WASD_V13"
    ScreenGui.ResetOnSpawn = false
    ScreenGui.Parent = LocalPlayer.PlayerGui

    -- Hàm tạo nút bấm tùy chỉnh
    local function CreateButton(name, text, pos)
        local Btn = Instance.new("TextButton")
        Btn.Name = name
        Btn.Text = text
        Btn.Position = pos
        Btn.Size = UDim2.new(0, 65, 0, 65)
        Btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        Btn.BackgroundTransparency = 0.4
        Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        Btn.Font = Enum.Font.GothamBold
        Btn.TextSize = 25
        Btn.Parent = ScreenGui

        -- Bo góc nút bấm
        local Corner = Instance.new("UICorner")
        Corner.CornerRadius = UDim.new(0, 15)
        Corner.Parent = Btn

        -- Viền cho nút
        local Stroke = Instance.new("UIStroke")
        Stroke.Thickness = 2
        Stroke.Color = Color3.fromRGB(255, 255, 255)
        Stroke.Parent = Btn

        return Btn
    end

    -- Vị trí cụm phím
    local BasePos = UDim2.new(0, 130, 0.65, 0)
    
    local W = CreateButton("W", "W", BasePos + UDim2.new(0, 0, 0, -75))
    local S = CreateButton("S", "S", BasePos + UDim2.new(0, 0, 0, 75))
    local A = CreateButton("A", "A", BasePos + UDim2.new(0, -75, 0, 0))
    local D = CreateButton("D", "D", BasePos + UDim2.new(0, 75, 0, 0))

    -- Biến trạng thái
    local Movement = { Forward = 0, Backward = 0, Left = 0, Right = 0 }

    -- Xử lý chạm
    local function Bind(btn, key, val)
        btn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                Movement[key] = val
                btn.BackgroundColor3 = Color3.fromRGB(0, 255, 127)
            end
        end)
        btn.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                Movement[key] = 0
                btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
            end
        end)
    end

    Bind(W, "Forward", 1)
    Bind(S, "Backward", 1)
    Bind(A, "Left", 1)
    Bind(D, "Right", 1)

    -- Vòng lặp di chuyển
    RunService.RenderStepped:Connect(function()
        local Hum = GetHumanoid()
        if Hum then
            local MoveDir = Vector3.new(Movement.Right - Movement.Left, 0, Movement.Backward - Movement.Forward)
            Hum:Move(MoveDir, true)
        end
    end)
    
    CreateNotification("WASD Mobile", "Đã kích hoạt phím di chuyển Iro!", 3)
end

