ExtraTab:CreateSection("Điều Chỉnh Cơ Thể")

ExtraTab:CreateSlider({
    Name = "Tốc Độ Chạy (WalkSpeed)",
    Range = {16, 500},
    Increment = 1,
    CurrentValue = 16,
    Callback = function(Value)
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            player.Character.Humanoid.WalkSpeed = Value
        end
    end,
})

ExtraTab:CreateSlider({
    Name = "Độ Cao Nhảy (JumpPower)",
    Range = {50, 800},
    Increment = 1,
    CurrentValue = 50,
    Callback = function(Value)
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            player.Character.Humanoid.UseJumpPower = true
            player.Character.Humanoid.JumpPower = Value
        end
    end,
})

ExtraTab:CreateSection("Gian Lận Chiến Đấu")

ExtraTab:CreateSlider({
    Name = "Kích Thước Hitbox",
    Range = {1, 10},
    Increment = 1,
    CurrentValue = 1,
    Callback = function(Value)
        _G.HitboxSize = Value
        _G.HitboxEnabled = true
        
        spawn(function()
            while _G.HitboxEnabled do
                for _, v in pairs(game:GetService("Players"):GetPlayers()) do
                    if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                        v.Character.HumanoidRootPart.Size = Vector3.new(_G.HitboxSize, _G.HitboxSize, _G.HitboxSize)
                        v.Character.HumanoidRootPart.Transparency = 0.7
                        v.Character.HumanoidRootPart.BrickColor = BrickColor.new("Really blue")
                        v.Character.HumanoidRootPart.Material = "Neon"
                        v.Character.HumanoidRootPart.CanCollide = false
                    end
                end
                task.wait(1)
            end
        end)
    end,
})

