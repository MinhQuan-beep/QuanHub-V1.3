-- 14. Anti Ban
MainTab:CreateToggle({
    Name = "Bảo Vệ Anti-Kick (Anti Ban)",
    CurrentValue = false,
    Callback = function(Value)
        QuanHub_Config.State.AntiBan = Value
        if Value then
            local raw = getrawmetatable(game)
            setreadonly(raw, false)
            local old = raw.__namecall
            raw.__namecall = newcclosure(function(self, ...)
                if getnamecallmethod() == "Kick" then 
                    SendNotification("Cảnh báo", "Hệ thống đã chặn một lệnh Kick từ Server.")
                    return nil 
                end
                return old(self, ...)
            end)
        end
    end,
})

