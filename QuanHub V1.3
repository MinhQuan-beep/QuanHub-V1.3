-- [ PHẦN 6: MODULE WASD MOBILE - BY IRO (CHI TIẾT 150 DÒNG) ]
---------------------------------------------------------------------------
local function Setup_WASD_Mobile()
    LogMessage("Đang khởi tạo module WASD Mobile...")
    
    -- Xóa các nút cũ nếu tồn tại
    if PlayerGui:FindFirstChild("QuânHub_WASD") then
        PlayerGui.QuânHub_WASD:Destroy()
        LogMessage("Đã xóa phiên bản WASD cũ")
    end

    -- Tạo giao diện chính
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "QuânHub_WASD"
    ScreenGui.ResetOnSpawn = false
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.Parent = PlayerGui

    -- Hàm xây dựng nút bấm chuyên sâu
    local function BuildControlKey(name, text, position)
        local button = Instance.new("TextButton")
        button.Name = name
        button.Text = text
        button.Position = position
        button.Size = UDim2.new(0, 65, 0, 65)
        button.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
        button.BackgroundTransparency = 0.5
        button.TextColor3 = Color3.fromRGB(255, 255, 255)
        button.Font = Enum.Font.GothamBold
        button.TextSize = 24
        button.AutoButtonColor = true
        button.Parent = ScreenGui

        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 12)
        corner.Parent = button

        local stroke = Instance.new("UIStroke")
        stroke.Thickness = 2.5
        stroke.Color = Color3.fromRGB(255, 255, 255)
        stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        stroke.Parent = button

        return button
    end

    -- Thiết lập tọa độ cụm phím WASD
    local OffsetX = 140
    local OffsetY = 0.65
    local KeyW = BuildControlKey("KeyW", "W", UDim2.new(0, OffsetX, OffsetY, -75))
    local KeyS = BuildControlKey("KeyS", "S", UDim2.new(0, OffsetX, OffsetY, 75))
    local KeyA = BuildControlKey("KeyA", "A", UDim2.new(0, OffsetX - 75, OffsetY, 0))
    local KeyD = BuildControlKey("KeyD", "D", UDim2.new(0, OffsetX + 75, OffsetY, 0))

    -- Biến trạng thái di chuyển
    local MoveState = {
        W = 0, S = 0, A = 0, D = 0
    }

    -- Xử lý sự kiện nhấn giữ (Touch/Mouse)
    local function ConnectInput(btn, key, val)
        btn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                MoveState[key] = val
                btn.BackgroundColor3 = Color3.fromRGB(0, 255, 127)
                btn.BackgroundTransparency = 0.2
            end
        end)
        btn.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                MoveState[key] = 0
                btn.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
                btn.BackgroundTransparency = 0.5
            end
        end)
    end

    ConnectInput(KeyW, "W", 1)
    ConnectInput(KeyS, "S", 1)
    ConnectInput(KeyA, "A", 1)
    ConnectInput(KeyD, "D", 1)

    -- Hệ thống điều hướng nhân vật không delay
    local MoveLoop = RunService.RenderStepped:Connect(function()
        local hum = GetLocalHumanoid()
        if hum then
            local direction = Vector3.new(MoveState.D - MoveState.A, 0, MoveState.S - MoveState.W)
            hum:Move(direction, true)
        end
    end)
    
    LogMessage("Đã bật WASD Mobile thành công.")
end

