SettingSection:NewToggle("Chế Độ Siêu Giảm Lag", "Xóa vật liệu và hiệu ứng nặng", function(state)
    if state then
        LogMessage("Đang thực hiện dọn dẹp tài nguyên...")
        for _, item in pairs(Workspace:GetDescendants()) do
            if item:IsA("BasePart") and not item:IsA("MeshPart") then
