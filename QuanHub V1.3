-- [ PHẦN 4: LOGIC ĐIỀU KHIỂN WASD MOBILE - BY IRO ]
---------------------------------------------------------------------------
local function ActivateCustomWASD()
    -- 1. Ẩn cụm di chuyển mặc định nhưng GIỮ LẠI nút Nhảy
    local function hideDefaultMovementOnly()
        local touchGui = PlayerGui:FindFirstChild("TouchGui")
        if touchGui then
            local touchControl = touchGui:FindFirstChild("TouchControlFrame")
            if touchControl then
                -- Ẩn DynamicThumbstick (vòng tròn di chuyển)
                local joystick = touchControl:FindFirstChild("DynamicThumbstickFrame") or touchControl:FindFirstChild("JoystickFrame")
                if joystick then
                    joystick.Visible = false
                end
                
                -- Đảm bảo nút Nhảy (JumpButton) vẫn hiện
                local jumpButton = touchControl:FindFirstChild("JumpButton")
                if jumpButton then
                    jumpButton.Visible = true
                end
            end
        end
    end

    -- Chạy hàm ẩn di chuyển
    hideDefaultMovementOnly()
    PlayerGui.ChildAdded:Connect(hideDefaultMovementOnly)

    -- 2. Dọn dẹp bản cũ nếu có
    if PlayerGui:FindFirstChild("CustomWASD_Iro") then
        PlayerGui.CustomWASD_Iro:Destroy()
    end

    -- 3. Tạo GUI cho cụm WASD
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "CustomWASD_Iro"
    screenGui.ResetOnSpawn = false
    screenGui.Parent = PlayerGui

    -- Hàm tạo nút di chuyển tròn
    local function createMoveBtn(name, text, pos, size)
        local btn = Instance.new("TextButton")
        btn.Name = name
        btn.Text = text
        btn.Position = pos
        btn.Size = size
        btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        btn.BackgroundTransparency = 0.5
        btn.TextColor3 = Color3.new(1, 1, 1)
        btn.Font = Enum.Font.SourceSansBold
        btn.TextSize = 20
        btn.AutoButtonColor = true
        btn.Parent = screenGui
        
        local uiCorner = Instance.new("UICorner")
        uiCorner.CornerRadius = UDim.new(1, 0) 
        uiCorner.Parent = btn
        
        return btn
    end

    -- 4. Cấu hình vị trí cụm WASD (Cao và Nhỏ)
    local yPos = 0.6 
    local centerLeft = UDim2.new(0, 130, yPos, 0) 
    local moveSize = UDim2.new(0, 55, 0, 55)

    local btnW = createMoveBtn("W", "W", centerLeft + UDim2.new(0, -27, 0, -65), moveSize)
    local btnS = createMoveBtn("S", "S", centerLeft + UDim2.new(0, -27, 0, 35), moveSize)
    local btnA = createMoveBtn("A", "A", centerLeft + UDim2.new(0, -85, 0, -15), moveSize)
    local btnD = createMoveBtn("D", "D", centerLeft + UDim2.new(0, 30, 0, -15), moveSize)

    -- 5. Logic điều khiển nhân vật
    local function getHumanoid()
        return LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
    end

    local moveState = {F = 0, B = 0, L = 0, R = 0}

    local function setupControl(btn, stateKey, val)
        btn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                moveState[stateKey] = val
                btn.BackgroundTransparency = 0.2
            end
        end)
        btn.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                moveState[stateKey] = 0
                btn.BackgroundTransparency = 0.5
            end
        end)
    end

    setupControl(btnW, "F", 1)
    setupControl(btnS, "B", 1)
    setupControl(btnA, "L", 1)
    setupControl(btnD, "R", 1)

    RunService.RenderStepped:Connect(function()
        local hum = getHumanoid()
        if hum then
            hum:Move(Vector3.new(moveState.R - moveState.L, 0, moveState.B - moveState.F), true)
        end
    end)
end

