--- [[ 2. TAB PREMIUM: VIP ONLY ]] ---
local function LoadPremiumFeatures()
    PremiumTab:CreateSection("🔥 Tuyệt Kỹ VIP")
    PremiumTab:CreateToggle({
        Name = "Chế Độ Bán Bất Tử (Semi-God)",
        CurrentValue = false,
        Callback = function(Value)
            _G.SemiGod = Value
            spawn(function()
                while _G.SemiGod do
                    if player.Character and player.Character:FindFirstChild("Humanoid") then
                        if player.Character.Humanoid.Health < 25 then
                            player.Character.Humanoid.Health = 100
                        end
                    end
                    task.wait(0.1)
                end
            end)
        end,
    })
    PremiumTab:CreateButton({
        Name = "Kích Hoạt Shader Menu (Icon)",
        Callback = function()
            -- Code Shader của Iro giữ nguyên
        end,
    })
    PremiumTab:CreateSection("⚡ Chỉ Số VIP")
    PremiumTab:CreateSlider({
        Name = "Tốc Độ Chạy (Speed)",
        Range = {16, 500},
        Increment = 1,
        CurrentValue = 16,
        Callback = function(v) if player.Character then player.Character.Humanoid.WalkSpeed = v end end,
    })
    PremiumTab:CreateSlider({
        Name = "Lực Nhảy (Jump Power)",
        Range = {50, 800},
        Increment = 1,
        CurrentValue = 50,
        Callback = function(v) if player.Character then player.Character.Humanoid.JumpPower = v player.Character.Humanoid.UseJumpPower = true end end,
    })
end

