-- [ PHẦN 5: CÁC HÀM XỬ LÝ NHÂN VẬT (CHARACTER HANDLERS) ]
---------------------------------------------------------------------------
local function GetLocalHumanoid()
    local char = LocalPlayer.Character
    if char then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            return humanoid
        else
            LogMessage("Không tìm thấy Humanoid")
        end
    end
    return nil
end

local function GetLocalRoot()
    local char = LocalPlayer.Character
    if char then
        local root = char:FindFirstChild("HumanoidRootPart")
        if root then
            return root
        else
            LogMessage("Không tìm thấy HumanoidRootPart")
        end
    end
    return nil
end

