MainTab:CreateToggle({
    Name = "Bảo Vệ Anti-Kick (Anti Ban)",
    CurrentValue = false,
    Callback = function(v)
        QuanHub_Registry.Settings.AntiBan = v
        if v then
            local raw = getrawmetatable(game)
            setreadonly(raw, false)
            local old = raw.__namecall
            raw.__namecall = newcclosure(function(self, ...)
                if getnamecallmethod() == "Kick" then return nil end
                return old(self, ...)
            end)
            QuickNotify("Bảo mật", "Đã kích hoạt chặn lệnh Kick.")
        end
    end,
})

