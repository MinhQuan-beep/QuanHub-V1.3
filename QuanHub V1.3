-- [ PHẦN 4: MODULE WASD MOBILE - BY IRO ]
---------------------------------------------------------------------------
local function ActivateCustomWASD()
    -- 1. Ẩn cụm di chuyển mặc định nhưng GIỮ LẠI nút Nhảy
    local function hideDefaultMovementOnly()
        local touchGui = PlayerGui:FindFirstChild("TouchGui")
        if touchGui then
            local touchControl = touchGui:FindFirstChild("TouchControlFrame")
            if touchControl then
                -- Ẩn DynamicThumbstick
                local joystick = touchControl:FindFirstChild("DynamicThumbstickFrame") or touchControl:FindFirstChild("JoystickFrame")
                if joystick then joystick.Visible = false end
                
                -- Đảm bảo nút Nhảy vẫn hiện
                local jumpButton = touchControl:FindFirstChild("JumpButton")
                if jumpButton then jumpButton.Visible = true end
            end
        end
    end

    hideDefaultMovementOnly()
    PlayerGui.ChildAdded:Connect(hideDefaultMovementOnly)

    -- 2. Dọn dẹp bản cũ
    if PlayerGui:FindFirstChild("CustomWASD_Iro") then
        PlayerGui.CustomWASD_Iro:Destroy()
    end

    -- 3. Tạo GUI
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "CustomWASD_Iro"
    screenGui.ResetOnSpawn = false
    screenGui.Parent = PlayerGui

    local function createMoveBtn(name, text, pos, size)
        local btn = Instance.new("TextButton")
        btn.Name = name
        btn.Text = text
        btn.Position = pos
        btn.Size = size
        btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        btn.BackgroundTransparency = 0.5
        btn.TextColor3 = Color3.new(1, 1, 1)
        btn.Font = Enum.Font.SourceSansBold
        btn.TextSize = 22
        btn.AutoButtonColor = true
        btn.Parent = screenGui
        
        local uiCorner = Instance.new("UICorner")
        uiCorner.CornerRadius = UDim.new(1, 0) 
        uiCorner.Parent = btn
        
        local uiStroke = Instance.new("UIStroke")
        uiStroke.Thickness = 1.5
        uiStroke.Color = Color3.new(1,1,1)
        uiStroke.Parent = btn
        
        return btn
    end

    -- Vị trí nút
    local yPos = 0.6 
    local centerLeft = UDim2.new(0, 130, yPos, 0) 
    local moveSize = UDim2.new(0, 58, 0, 58)

    local btnW = createMoveBtn("W", "W", centerLeft + UDim2.new(0, -29, 0, -68), moveSize)
    local btnS = createMoveBtn("S", "S", centerLeft + UDim2.new(0, -29, 0, 38), moveSize)
    local btnA = createMoveBtn("A", "A", centerLeft + UDim2.new(0, -88, 0, -15), moveSize)
    local btnD = createMoveBtn("D", "D", centerLeft + UDim2.new(0, 33, 0, -15), moveSize)

    -- Logic WASD
    local moveState = {F = 0, B = 0, L = 0, R = 0}

    local function setupControl(btn, stateKey, val)
        btn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                moveState[stateKey] = val
                TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundTransparency = 0.2}):Play()
            end
        end)
        btn.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                moveState[stateKey] = 0
                TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundTransparency = 0.5}):Play()
            end
        end)
    end

    setupControl(btnW, "F", 1)
    setupControl(btnS, "B", 1)
    setupControl(btnA, "L", 1)
    setupControl(btnD, "R", 1)

    RunService.RenderStepped:Connect(function()
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid:Move(Vector3.new(moveState.R - moveState.L, 0, moveState.B - moveState.F), true)
        end
    end)
end

