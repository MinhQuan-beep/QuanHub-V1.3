local function QuickNotify(title, content)
    Rayfield:Notify({
        Title = title,
        Content = content,
        Duration = 5,
        Image = 4483362458,
    })
end

local function ExecutionWrapper(taskName, func)
    local s, e = pcall(func)
    if not s then
        warn(QuanHub_Registry.Meta.Prefix .. " Lỗi: " .. taskName .. " | " .. tostring(e))
    end
end

