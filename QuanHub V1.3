-- [ PHẦN 4: MODULE WASD MOBILE - BY IRO (FULL DETAIL) ]
---------------------------------------------------------------------------
local function LaunchWASD()
    -- Xử lý ẩn nút mặc định chuyên sâu
    local function cleanDefaultUI()
        local touchGui = PlayerGui:FindFirstChild("TouchGui")
        if touchGui then
            local controlFrame = touchGui:FindFirstChild("TouchControlFrame")
            if controlFrame then
                local joystick = controlFrame:FindFirstChild("DynamicThumbstickFrame") or controlFrame:FindFirstChild("JoystickFrame")
                if joystick then
                    joystick.Visible = false
                end
                local jump = controlFrame:FindFirstChild("JumpButton")
                if jump then
                    jump.Visible = true
                end
            end
        end
    end

    cleanDefaultUI()
    PlayerGui.ChildAdded:Connect(cleanDefaultUI)

    -- Dọn dẹp bản cũ nếu người dùng bấm nút nhiều lần
    if PlayerGui:FindFirstChild("Iro_WASD_UI") then
        PlayerGui.Iro_WASD_UI:Destroy()
    end

    -- Tạo ScreenGui mới cho cụm phím
    local wasdGui = Instance.new("ScreenGui")
    wasdGui.Name = "Iro_WASD_UI"
    wasdGui.ResetOnSpawn = false
    wasdGui.Parent = PlayerGui

    -- Hàm xây dựng nút bấm chi tiết (Hơn 40 dòng cho phần GUI)
    local function buildButton(name, txt, pos)
        local b = Instance.new("TextButton")
        b.Name = name
        b.Text = txt
        b.Position = pos
        b.Size = UDim2.new(0, 55, 0, 55)
        b.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        b.BackgroundTransparency = 0.5
        b.TextColor3 = Color3.new(1, 1, 1)
        b.Font = Enum.Font.SourceSansBold
        b.TextSize = 20
        b.Parent = wasdGui
        
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(1, 0)
        corner.Parent = b
        
        local stroke = Instance.new("UIStroke")
        stroke.Thickness = 1.5
        stroke.Color = Color3.new(1, 1, 1)
        stroke.Parent = b
        
        return b
    end

    -- Định vị cụm phím theo yêu cầu của Iro
    local anchor = UDim2.new(0, 130, 0.6, 0)
    local btnW = buildButton("W", "W", anchor + UDim2.new(0, -27, 0, -65))
    local btnS = buildButton("S", "S", anchor + UDim2.new(0, -27, 0, 35))
    local btnA = buildButton("A", "A", anchor + UDim2.new(0, -85, 0, -15))
    local btnD = buildButton("D", "D", anchor + UDim2.new(0, 30, 0, -15))

    -- Trạng thái di chuyển (Movement Logic)
    local state = {Forward = 0, Backward = 0, Left = 0, Right = 0}

    local function applyInput(btn, key, val)
        btn.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.Touch or inp.UserInputType == Enum.UserInputType.MouseButton1 then
                state[key] = val
                TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundTransparency = 0.2}):Play()
            end
        end)
        btn.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.Touch or inp.UserInputType == Enum.UserInputType.MouseButton1 then
                state[key] = 0
                TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundTransparency = 0.5}):Play()
            end
        end)
    end

    applyInput(btnW, "Forward", 1)
    applyInput(btnS, "Backward", 1)
    applyInput(btnA, "Left", 1)
    applyInput(btnD, "Right", 1)

    -- Vòng lặp điều hướng nhân vật không độ trễ
    RunService.RenderStepped:Connect(function()
        local h = GetHumanoid()
        if h then
            h:Move(Vector3.new(state.Right - state.Left, 0, state.Backward - state.Forward), true)
        end
    end)
end

